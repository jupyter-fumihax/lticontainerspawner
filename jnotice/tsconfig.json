{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "ES2019",
    "lib": ["DOM", "ES2019"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": [
    "labextension/**/*.ts"
  ]
}
